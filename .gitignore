# ============================================================
# Voelgoed Course Bridge - Git Ignore Rules
# Repo contains:
# - Sender plugin for winkel.voelgoed.co.za
# - Receiver plugin for leer.voelgoed.co.za
# ============================================================


# ============================================================
# Operating system files
# ============================================================

.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini


# ============================================================
# Editor / IDE files
# ============================================================

.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Keep optional shared VS Code recommendations if you later add them manually.
!.vscode/extensions.json
!.vscode/settings.json


# ============================================================
# Local environment and secrets
# Never commit secrets, API keys, shared HMAC keys, or local config.
# ============================================================

.env
.env.*
*.env
*.key
*.pem
*.crt
*.p12
*.pfx
auth.json
wp-config.php
wp-config-local.php
local-config.php


# ============================================================
# WordPress local development files
# Useful if you ever test inside a full local WordPress install.
# ============================================================

wp-content/uploads/
wp-content/cache/
wp-content/upgrade/
wp-content/backup*/
wp-content/backups/
wp-content/debug.log
wp-content/*.log

# WordPress generated files
.htaccess
.user.ini


# ============================================================
# Logs and debug output
# ============================================================

*.log
logs/
debug.log
error_log
php_errors.log


# ============================================================
# Temporary files
# ============================================================

tmp/
temp/
.cache/
*.tmp
*.temp
*.bak
*.swp
*.swo
*~


# ============================================================
# Build and release artifacts
# Source plugin folders stay tracked.
# Generated ZIP files should not be committed.
# ============================================================

releases/*
!releases/.gitkeep

build/
dist/
*.zip
*.tar
*.tar.gz


# ============================================================
# Dependency folders
# Only commit these intentionally if the plugin later requires bundled vendor files.
# ============================================================

node_modules/
vendor/


# ============================================================
# Composer / PHP tooling cache
# ============================================================

.composer/
.phpunit.result.cache
.phpunit.cache/
coverage/


# ============================================================
# npm / JS tooling cache
# ============================================================

.npm/
.yarn/
.yarn-cache/
pnpm-lock.yaml
package-lock.json
yarn.lock


# ============================================================
# Database exports and backups
# Never commit SQL dumps or site backups.
# ============================================================

*.sql
*.sql.gz
*.sqlite
*.sqlite3
*.db
*.dump
*.backup
*.wpress
*.tar.gz
*.7z
*.rar


# ============================================================
# Deployment / FTP / SFTP metadata
# ============================================================

.deploy/
deployment/
.sftp-config.json
ftp-config.json


# ============================================================
# Mac / Windows archive extraction leftovers
# ============================================================

__MACOSX/
*.icloud